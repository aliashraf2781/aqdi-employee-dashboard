{
  "description": "API contract for قسم التعليمات - صور تعليمية أو إعلانية (Educational / Instruction Images). Frontend expects Arabic fields. Follow same response wrapper as FAQs: { message, code, success, data }.",
  "base_path": "/api/admin",
  "endpoints": [
    {
      "name": "List all sections with images",
      "method": "GET",
      "url": "/instruction-sections",
      "query": {
        "per_page": 20,
        "page": 1
      },
      "response_example": {
        "message": "نجحت العملية",
        "code": 200,
        "success": true,
        "data": {
          "items": [
            {
              "id": 1,
              "key": "new-client",
              "title_ar": "عميل جديد",
              "description_ar": "صورة تظهر للعملاء - الجدد",
              "is_active": true,
              "sort_order": 1,
              "images": [
                {
                  "id": 101,
                  "section_id": 1,
                  "title_ar": "العقد #10001",
                  "image_url": "https://example.com/storage/instructions/101.png",
                  "mime_type": "image/png",
                  "file_extension": "png",
                  "sort_order": 1,
                  "created_at": "2026-05-04T07:57:38.000000Z",
                  "updated_at": "2026-05-04T07:57:38.000000Z"
                }
              ],
              "created_at": "2026-05-04T07:57:38.000000Z",
              "updated_at": "2026-05-04T07:57:38.000000Z"
            }
          ],
          "pagination": {
            "current_page": 1,
            "last_page": 2,
            "per_page": 20,
            "total": 20,
            "from": 1,
            "to": 20,
            "next_page_url": null,
            "prev_page_url": null
          }
        }
      }
    },
    {
      "name": "Get single section with images (for edit/view modal)",
      "method": "GET",
      "url": "/instruction-sections/{id}",
      "response_example": {
        "message": "نجحت العملية",
        "code": 200,
        "success": true,
        "data": {
          "id": 1,
          "key": "new-client",
          "title_ar": "عميل جديد",
          "description_ar": "صورة تظهر للعملاء - الجدد",
          "is_active": true,
          "sort_order": 1,
          "images": [
            {
              "id": 101,
              "section_id": 1,
              "title_ar": "العقد #10001",
              "image_url": "https://example.com/storage/instructions/101.png",
              "mime_type": "image/png",
              "file_extension": "png",
              "sort_order": 1
            }
          ]
        }
      }
    },
    {
      "name": "Create new section (زر: إضافة صورة تعليمية جديدة)",
      "method": "POST",
      "url": "/instruction-sections",
      "content_type": "application/json",
      "request_body": {
        "title_ar": "عنوان القسم",
        "description_ar": "وصف يظهر تحت العنوان في البطاقة",
        "key": "optional-unique-slug",
        "is_active": true,
        "sort_order": 21
      },
      "request_example": {
        "title_ar": "قسم جديد",
        "description_ar": "صورة تظهر في مكان محدد",
        "key": "custom-section",
        "is_active": true,
        "sort_order": 21
      },
      "response_example": {
        "message": "تم إضافة القسم بنجاح",
        "code": 200,
        "success": true,
        "data": {
          "id": 21,
          "key": "custom-section",
          "title_ar": "قسم جديد",
          "description_ar": "صورة تظهر في مكان محدد",
          "is_active": true,
          "sort_order": 21,
          "images": []
        }
      }
    },
    {
      "name": "Update section (title, description, sort)",
      "method": "POST",
      "url": "/instruction-sections/{id}",
      "content_type": "application/json",
      "request_body": {
        "title_ar": "string (optional)",
        "description_ar": "string (optional)",
        "is_active": "boolean (optional)",
        "sort_order": "integer (optional)"
      },
      "request_example": {
        "title_ar": "عميل جديد",
        "description_ar": "صورة تظهر للعملاء - الجدد",
        "is_active": true,
        "sort_order": 1
      }
    },
    {
      "name": "Toggle section active only (switch on card)",
      "method": "POST",
      "url": "/instruction-sections/{id}/toggle",
      "content_type": "application/json",
      "request_body": {
        "is_active": true
      },
      "request_example": {
        "is_active": false
      },
      "notes": "Alternative: use POST /instruction-sections/{id} with { is_active: true|false } only."
    },
    {
      "name": "Delete section",
      "method": "POST",
      "url": "/instruction-sections/{id}/delete",
      "request_body": null,
      "notes": "Should also delete all images under this section."
    },
    {
      "name": "Upload image to section (modal: تحميل الصورة + إضافة)",
      "method": "POST",
      "url": "/instruction-sections/{section_id}/images",
      "content_type": "multipart/form-data",
      "request_body": {
        "image": "file (required) - png, jpg, jpeg, webp",
        "title_ar": "string (optional) - display name e.g. العقد #10001",
        "sort_order": "integer (optional)"
      },
      "request_example_form_fields": {
        "image": "<binary file>",
        "title_ar": "العقد #10004",
        "sort_order": 4
      },
      "response_example": {
        "message": "تم رفع الصورة بنجاح",
        "code": 200,
        "success": true,
        "data": {
          "id": 104,
          "section_id": 1,
          "title_ar": "العقد #10004",
          "image_url": "https://example.com/storage/instructions/104.png",
          "mime_type": "image/png",
          "file_extension": "png",
          "sort_order": 4,
          "created_at": "2026-05-04T10:00:00.000000Z",
          "updated_at": "2026-05-04T10:00:00.000000Z"
        }
      }
    },
    {
      "name": "Update image metadata",
      "method": "POST",
      "url": "/instruction-sections/{section_id}/images/{image_id}",
      "content_type": "application/json",
      "request_body": {
        "title_ar": "string (optional)",
        "sort_order": "integer (optional)"
      },
      "request_example": {
        "title_ar": "العقد #10001 - محدث"
      }
    },
    {
      "name": "Replace image file",
      "method": "POST",
      "url": "/instruction-sections/{section_id}/images/{image_id}/replace",
      "content_type": "multipart/form-data",
      "request_body": {
        "image": "file (required)"
      }
    },
    {
      "name": "Delete image (trash icon in modal)",
      "method": "POST",
      "url": "/instruction-sections/{section_id}/images/{image_id}/delete",
      "request_body": null
    }
  ],
  "field_mapping_frontend": {
    "card_title": "title_ar",
    "card_description": "description_ar",
    "card_switch": "is_active",
    "modal_file_name": "title_ar",
    "modal_file_type": "file_extension",
    "modal_preview": "image_url",
    "section_identifier": "key"
  },
  "predefined_section_keys": [
    "new-client",
    "start",
    "housing-contract",
    "commercial-contract",
    "my-properties",
    "units",
    "deed",
    "address",
    "owner",
    "tenant",
    "financial",
    "payment-complete",
    "orders",
    "order-details",
    "whatsapp",
    "profile",
    "notifications",
    "support",
    "faq",
    "welcome"
  ],
  "validation_rules": {
    "title_ar": "required|string|max:255",
    "description_ar": "required|string|max:500",
    "key": "nullable|string|max:100|unique:instruction_sections,key",
    "is_active": "boolean",
    "image": "required|file|mimes:png,jpg,jpeg,webp|max:5120"
  },
  "errors_example": {
    "message": "بيانات غير صالحة",
    "code": 422,
    "success": false,
    "errors": {
      "title_ar": ["حقل العنوان مطلوب"],
      "image": ["يجب أن تكون الصورة بصيغة png أو jpg"]
    }
  }
}
